<?xml version="1.0" encoding="utf-8"?>
<!--
  纯 WebView 壳：不依赖 Material Components / AppCompat 库，直接用平台内置主题。
  - Theme.Material（API 21+，minSdk 26 满足）深色基底，避免冷启动白闪。
  - colorPrimary 等 Material 属性未在代码中使用（全屏 WebView + 平台 Button/EditText），移除。
  - 仅保留状态栏/导航栏颜色与窗口背景。
-->
<resources>
    <style name="Theme.PiMobile" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:statusBarColor">#0a2647</item>
        <item name="android:navigationBarColor">#0a2647</item>
        <item name="android:windowBackground">#1A1A2E</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>
